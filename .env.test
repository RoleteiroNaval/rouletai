# ============================================
# CONFIGURAÇÃO DE TESTE
# ============================================

# Usar credenciais fake para testes
TELEGRAM_TOKEN=test_token_123456789
TELEGRAM_CHAT_ID=123456789

# WebSocket de teste (mock)
PLAYTECH_WS_URL=wss://test.example.com/ws

# URLs de teste
GAME_URL=https://test.example.com

# Modo test
HEADLESS=true
ENGINE_DEBUG=true
LOG_LEVEL=DEBUG

# Database de teste
DATABASE_PATH=./data/test.sqlite

# Sem encriptação em testes
ENCRYPTION_ENABLED=false

# Desabilitar notificações reais
TELEGRAM_ALERTS=false

# Modo test para CI/CD
DEPLOYMENT_ENV=test
