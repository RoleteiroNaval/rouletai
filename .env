# ================================================================
#  SKYNETCHAT SYSTEM — Configuração Completa
#  Arquivo: config/.env  (ou raiz do projeto)
#  NUNCA compartilhe este arquivo publicamente!
# ================================================================


# ═══════════════════════════════════════════════════════════════
#  TELEGRAM (OBRIGATÓRIO)
# ═══════════════════════════════════════════════════════════════

# Token do bot — obtenha via @BotFather → /newbot
# ⚠️ SE ESTE TOKEN FOI EXPOSTO, revogue em @BotFather → /revoke
TELEGRAM_TOKEN=SEU_TOKEN_AQUI

# ID do chat/grupo onde os sinais são enviados
# Obtenha via @userinfobot → /start
TELEGRAM_CHAT_ID=SEU_CHAT_ID_AQUI


# ═══════════════════════════════════════════════════════════════
#  JOGO / API
# ═══════════════════════════════════════════════════════════════

GAME_URL=https://geralbet.bet.br/games/playtech/roleta-brasileira
API_URL=https://api.geralbet.bet.br
API_KEY=SEU_API_KEY_AQUI


# ═══════════════════════════════════════════════════════════════
#  APOSTAS
# ═══════════════════════════════════════════════════════════════

BET_AMOUNT=100
WAIT_ROUNDS_AFTER_WIN=1
WAIT_ROUNDS_AFTER_ZERO=5


# ═══════════════════════════════════════════════════════════════
#  VOICE — AGENTE DE VOZ (gTTS + WebSocket)
# ═══════════════════════════════════════════════════════════════

# Habilita ou desabilita o sistema de voz
VOICE_ENABLED=true

# Endereço WebSocket do servidor de voz
# Use ws://localhost:8765 para rodar local no Windows
VOICE_WS=ws://localhost:8765

# Token de autenticação do servidor de voz
VOICE_TOKEN=win_secret_2024

# Host e porta onde o servidor WebSocket escuta
# 0.0.0.0 = aceita conexões de qualquer interface
VOICE_WS_HOST=0.0.0.0
VOICE_WS_PORT=8765

# Porta HTTP para o PWA (interface web)
VOICE_HTTP_PORT=8080

# Engine de voz: gtts | pyttsx3 | elevenlabs
VOICE_ENGINE=gtts

# Idioma da síntese de voz (gTTS)
# pt = Português, pt-br = Português do Brasil
VOICE_LANG=pt

# Cooldown entre alertas de voz do mesmo número (segundos)
# Evita repetição excessiva do mesmo sinal
VOICE_COOLDOWN=30

# Confiança mínima para disparar alerta de voz (0.0 a 1.0)
VOICE_MIN_CONFIDENCE=0.65

# Tamanho máximo da fila de voz
VOICE_QUEUE_SIZE=50


# ═══════════════════════════════════════════════════════════════
#  WEBSOCKET GERAL
# ═══════════════════════════════════════════════════════════════

# Habilita servidor WebSocket
WS_ENABLED=true

# Porta base — se ocupada, o sistema tenta a próxima automaticamente
# Resolve OSError [10048] no Windows
WS_BASE_PORT=8765
WS_MAX_PORT_ATTEMPTS=20


# ═══════════════════════════════════════════════════════════════
#  FORMATAÇÃO DE MENSAGENS
# ═══════════════════════════════════════════════════════════════

GAME_NAME=🎰 ROLETA BRASILEIRA
SIGNAL_HEADER=🚦 SINALZINHO GRATUITO 🚦
TIMEZONE=GMT-3
ROULETTE_LINK=https://geralbet.bet.br/games/playtech/roleta-brasileira
STRATEGY_LINK=https://t.me/seu_canal_aqui


# ═══════════════════════════════════════════════════════════════
#  STICKERS TELEGRAM
# ═══════════════════════════════════════════════════════════════

STICKER_WIN=CAACAgEAAxkBAAEQrk5pqT1iqq3X4txpIYC5Zz335RMSWgACVgYAAiIkwUeIG8kG138VVToE
STICKER_LOSS=CAACAgEAAxkBAAEQrlJpqT2RHY_31n7BgEPyctskk4PWywACgwYAAqI9wEdLoqFxrrDknToE


# ═══════════════════════════════════════════════════════════════
#  SISTEMA / DEBUG
# ═══════════════════════════════════════════════════════════════

# Nível de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Modo debug (mais logs, sem envio real ao Telegram)
DEBUG=false

# Intervalo do watchdog em segundos
HEALTH_INTERVAL=30

# Backoff de reconexão
RECONNECT_BASE=1
RECONNECT_MAX=60

# Tamanho máximo da fila Telegram
TG_QUEUE_MAXSIZE=100

# Segundos mínimos entre mensagens Telegram (rate limit)
TG_RATE_LIMIT=1.0
